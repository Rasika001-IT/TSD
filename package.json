{
  "name": "tsd-publishing-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CMS-neutral editorial publishing system: agent (policy) + bridge (mechanism) + swappable per-CMS adapters + React review dashboard.",
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "bridge": "node bridge/index.js",
    "dashboard:api": "node dashboard/server.js",
    "dashboard": "npm --workspace dashboard run dev",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "pg": "^8.12.0"
  },
  "engines": {
    "node": ">=20"
  }
}
