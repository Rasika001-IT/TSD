# Copy to .env and fill in for a real deployment. The system boots in memory
# mode with none of this set — see README "Quick start".

# --- Repository driver ------------------------------------------------------
DB_DRIVER=memory            # memory | postgres
DATABASE_URL=               # Supabase Postgres connection string (DB_DRIVER=postgres)

# --- Content-generation agent (Claude) --------------------------------------
# Used by `npm run generate`. Without it, generation is disabled (the rest of
# the system still runs). Use the project's dedicated Claude account key.
ANTHROPIC_API_KEY=

# --- WordPress adapter (Application Password auth) --------------------------
WP_BASE_URL=                # e.g. https://example.com
WP_USERNAME=
WP_APP_PASSWORD=
WP_SEO_PLUGIN=               # yoast | rankmath (optional)

# --- Bridge poller -----------------------------------------------------------
BRIDGE_POLL_INTERVAL_MS=15000
BRIDGE_BATCH_SIZE=10
BRIDGE_DEFAULT_MAX_ATTEMPTS=5
BRIDGE_BACKOFF_BASE_MS=1000
BRIDGE_BACKOFF_MAX_MS=300000

# --- Dashboard backend --------------------------------------------------------
DASH_PORT=4000
DASH_TOKEN=dev-token         # placeholder auth header value
